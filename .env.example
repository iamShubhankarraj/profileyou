# Auto-DM Server Configuration

# The port Express will listen on
PORT=3005

# Webhook Verification Token (Choose a random string, you must input the same in the Meta developer panel)
VERIFY_TOKEN=subh_tle_verify_token_123

# Facebook Page Access Token (Obtained from Meta App Dashboard)
PAGE_ACCESS_TOKEN=your_meta_page_access_token_here

# Automation Defaults (can be dynamically overridden in the UI)
DEFAULT_TRIGGER_WORD=pipeline
DEFAULT_DM_MESSAGE=Hey! Thanks for commenting. Here is the link to the Google Drive Handover files: https://gdrive.link/pipeline
